<%# Login page — matches Know-How UI design %>
<div class="auth-page">
  <div class="auth-card">

    <%# Logo %>
    <div class="auth-logo">
      <i class="fa-solid fa-lightbulb"></i>
      <span>Know-How</span>
    </div>

    <%# Heading %>
    <h1 class="auth-title">Join the Know-How Community</h1>
    <p class="auth-subtitle">Discover and share expertise with the world.</p>

    <%# Tab toggle: Log In / Sign Up %>
    <div class="auth-tabs">
      <%= link_to "Log In", new_user_session_path, class: "auth-tab active" %>
      <%= link_to "Sign Up", new_user_registration_path, class: "auth-tab" %>
    </div>

    <%# Login form %>
    <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="auth-form">
        <%# Email field %>
        <div class="auth-field">
          <label class="auth-label">Email</label>
          <%= f.input :email,
                      label: false,
                      required: false,
                      autofocus: true,
                      placeholder: "name@example.com",
                      input_html: { autocomplete: "email", class: "auth-input" } %>
        </div>

        <%# Password field with Forgot Password link %>
        <div class="auth-field">
          <div class="d-flex justify-content-between align-items-center">
            <label class="auth-label">Password</label>
            <%= link_to "Forgot Password?", new_password_path(resource_name), class: "auth-forgot-link" %>
          </div>
          <div class="auth-input-wrapper">
            <%= f.input :password,
                        label: false,
                        required: false,
                        placeholder: "\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022",
                        input_html: { autocomplete: "current-password", class: "auth-input", id: "passwordInput" } %>
            <button type="button" class="auth-eye-btn" onclick="togglePassword()">
              <i class="fa-regular fa-eye" id="eyeIcon"></i>
            </button>
          </div>
        </div>

        <%# Submit button %>
        <%= f.button :submit, "Log In", class: "btn auth-btn" %>
      </div>
    <% end %>

    <%# OAuth divider — visual only until OmniAuth is configured %>
    <div class="auth-divider">
      <span>OR CONTINUE WITH</span>
    </div>

    <%# OAuth buttons — placeholders until OmniAuth is set up %>
    <div class="auth-oauth">
      <button type="button" class="btn auth-oauth-btn" disabled>
        <i class="fa-brands fa-google"></i> Google
      </button>
      <button type="button" class="btn auth-oauth-btn" disabled>
        <i class="fa-brands fa-apple"></i> Apple
      </button>
    </div>

    <%# Sign up link — pinned to bottom %>
    <div class="auth-footer">
      <p class="auth-switch">
        Don't have an account? <%= link_to "Sign Up", new_user_registration_path, class: "auth-switch-link" %>
      </p>
    </div>

  </div>
</div>

<%# JS: password show/hide toggle %>
<script>
  function togglePassword() {
    const input = document.getElementById("passwordInput");
    const icon  = document.getElementById("eyeIcon");
    if (input.type === "password") {
      input.type = "text";
      icon.classList.replace("fa-eye", "fa-eye-slash");
    } else {
      input.type = "password";
      icon.classList.replace("fa-eye-slash", "fa-eye");
    }
  }
</script>
