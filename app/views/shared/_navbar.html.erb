<%# Bottom navigation bar — 3 tabs: Scanner (home), Explore, Profile %>
<nav class="bottom-navbar">
  <div class="bottom-navbar-inner">

    <%# Scanner tab — links to root (homepage) %>
    <%= link_to root_path, class: "bottom-navbar-tab #{current_page?(root_path) ? 'active' : ''}" do %>
      <i class="fa-solid fa-camera"></i>
      <span>SCANNER</span>
    <% end %>

    <%# Explore tab — links to explore page %>
    <%= link_to explore_path, class: "bottom-navbar-tab #{current_page?(explore_path) ? 'active' : ''}" do %>
      <i class="fa-solid fa-compass"></i>
      <span>EXPLORE</span>
    <% end %>

    <%# Profile tab — login if not signed in, profile page if signed in %>
    <% if user_signed_in? %>
      <%= link_to profile_path, class: "bottom-navbar-tab #{current_page?(profile_path) ? 'active' : ''}" do %>
        <i class="fa-solid fa-user"></i>
        <span>PROFILE</span>
      <% end %>
    <% else %>
      <%= link_to new_user_session_path, class: "bottom-navbar-tab #{current_page?(new_user_session_path) ? 'active' : ''}" do %>
        <i class="fa-solid fa-user"></i>
        <span>PROFILE</span>
      <% end %>
    <% end %>

  </div>
</nav>
