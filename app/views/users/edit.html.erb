<%# Edit Profile page — matches Know-How UI design %>
<div class="profile-page">

  <%# Header %>
  <%# Header: back arrow only %>
  <div class="profile-header">
    <%= link_to profile_path, class: "profile-header-link" do %>
      <i class="fa-solid fa-arrow-left"></i>
    <% end %>
  </div>

  <%= form_with model: @user, url: profile_path, method: :patch, multipart: true, class: "edit-profile-form" do |f| %>

    <%# Flash errors %>
    <% if @user.errors.any? %>
      <div class="alert alert-danger rounded-3 mb-3">
        <% @user.errors.full_messages.each do |msg| %>
          <p class="mb-0"><%= msg %></p>
        <% end %>
      </div>
    <% end %>

    <%# Photo upload circle %>
    <div class="edit-avatar-section">
      <div class="edit-avatar-wrapper">
        <div class="edit-avatar" id="avatarPreview">
          <% if @user.picture.present? %>
            <%= image_tag @user.picture, class: "edit-avatar-img", id: "avatarImg" %>
          <% else %>
            <i class="fa-solid fa-user edit-avatar-placeholder" id="avatarIcon"></i>
          <% end %>
        </div>
        <%# Camera button outside the overflow:hidden div so it stays clickable %>
        <label for="photoInput" class="edit-avatar-camera">
          <i class="fa-solid fa-camera"></i>
        </label>
      </div>
      <%= f.file_field :photo, id: "photoInput", accept: "image/*", class: "d-none" %>
      <p class="edit-avatar-hint">Update Photo</p>
    </div>

    <%# Full Name %>
    <div class="auth-field">
      <%= f.label :full_name, "Full Name", class: "auth-label" %>
      <%= f.text_field :full_name, value: @user.full_name, placeholder: "Enter your full name", class: "auth-input" %>
    </div>

    <%# Username %>
    <div class="auth-field">
      <%= f.label :username, "Username", class: "auth-label" %>
      <%= f.text_field :username, value: @user.username, placeholder: "Choose a username", class: "auth-input" %>
    </div>

    <%# Email %>
    <div class="auth-field">
      <%= f.label :email, "Email", class: "auth-label" %>
      <%= f.email_field :email, value: @user.email, placeholder: "example@email.com", class: "auth-input" %>
    </div>

    <%# Save + Delete pinned to bottom via margin-top: auto %>
    <div class="edit-profile-actions">
      <%= f.submit "Save Changes", class: "btn auth-btn w-100" %>
      <%= link_to "Delete Account", registration_path(:user), data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete your account? This cannot be undone." }, class: "edit-profile-delete" %>
    </div>

  <% end %>

</div>

<%# JS: live photo preview %>
<script>
  document.getElementById("photoInput").addEventListener("change", function(e) {
    const file = e.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = function(ev) {
      const preview = document.getElementById("avatarPreview");
      // Replace icon with image if not already showing one
      let img = document.getElementById("avatarImg");
      if (!img) {
        const icon = document.getElementById("avatarIcon");
        if (icon) icon.remove();
        img = document.createElement("img");
        img.id = "avatarImg";
        img.className = "edit-avatar-img";
        preview.insertBefore(img, preview.querySelector(".edit-avatar-camera"));
      }
      img.src = ev.target.result;
    };
    reader.readAsDataURL(file);
  });
</script>
