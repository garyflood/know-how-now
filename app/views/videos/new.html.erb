<%# Creator Submission — video upload form %>
<% content_for :title, "Creator Submission" %>

<div class="upload-page" data-controller="upload">

  <%# Upload progress overlay — hidden until form is submitted %>
  <div class="upload-overlay" data-upload-target="overlay" style="display: none;">
    <%# Progress state %>
    <div class="upload-progress-card" data-upload-target="progressCard">
      <div class="upload-progress-icon">
        <i class="fa-solid fa-cloud-arrow-up"></i>
      </div>
      <p class="upload-progress-label">Uploading video...</p>
      <div class="upload-progress-track">
        <div class="upload-progress-fill" data-upload-target="progressBar"></div>
      </div>
      <p class="upload-progress-pct" data-upload-target="progressPct">0%</p>
    </div>

    <%# Success state — shown after upload completes %>
    <div class="upload-success-card" data-upload-target="successCard" style="display: none;">
      <div class="upload-success-icon">
        <i class="fa-solid fa-circle-check"></i>
      </div>
      <p class="upload-success-title">Upload Successful!</p>
      <p class="upload-success-sub">Taking you to your video...</p>
    </div>
  </div>

  <%# Header: back arrow + title %>
  <div class="upload-header">
    <%= link_to profile_path, class: "upload-back-link" do %>
      <i class="fa-solid fa-arrow-left"></i>
    <% end %>
    <h1 class="upload-header-title">Creator Submission</h1>
    <span class="upload-header-spacer"></span>
  </div>

  <%= form_with url: user_videos_path(current_user), scope: :video, method: :post,
        html: { multipart: true, class: "upload-form",
                data: { turbo: false, action: "submit->upload#submit" } } do |f| %>

    <%# Validation errors %>
    <% if @video.errors.any? %>
      <div class="upload-errors">
        <% @video.errors.full_messages.each do |msg| %>
          <p><%= msg %></p>
        <% end %>
      </div>
    <% end %>

    <% if flash[:alert].present? %>
      <div class="upload-errors">
        <p><%= flash[:alert] %></p>
      </div>
    <% end %>

    <%# ── Section 1: Confirm Device Model ── %>
    <div class="upload-section">
      <h2 class="upload-section-title">Confirm Device Model</h2>
      <div class="upload-field">
        <label class="upload-label" for="device_name">Model Name</label>
        <div class="upload-input-wrapper">
          <%= text_field_tag :device_name, params[:device_name],
                id: "device_name",
                placeholder: "e.g. Sony WH-1000XM5",
                required: true,
                class: "upload-input#{' upload-input--error' if params[:duplicate_device].present?}",
                data: { action: "input->upload#updateCheck" } %>
          <i class="fa-regular fa-circle-check upload-input-check" id="deviceNameCheck"></i>
        </div>
        <% if params[:duplicate_device].present? %>
          <p class="upload-field-error"><%= params[:duplicate_device] %> already has a linked video</p>
        <% end %>
        <p class="upload-hint">Ensure the model name exactly matches the label on your device or its original packaging.</p>
      </div>
    </div>

    <%# ── Section 2: Upload Device Photo ── %>
    <div class="upload-section">
      <h2 class="upload-section-title">Upload Device Photo</h2>
      <p class="upload-section-desc">Please take clear, well-lit photos of the physical device (at least one) you will be featuring in the manual. This helps us verify the version.</p>

      <label class="upload-dropzone" for="device_images">
        <div class="upload-dropzone-icon">
          <i class="fa-solid fa-camera"></i>
        </div>
        <p class="upload-dropzone-title">Tap to upload photos</p>
        <p class="upload-dropzone-sub">JPG, PNG up to 2MB</p>
        <%= file_field_tag "device_images[]", accept: "image/*", multiple: true,
              class: "upload-file-input", id: "device_images",
              data: { action: "change->upload#previewPhotos" } %>
      </label>

      <%# Photo thumbnails appear here after selection %>
      <div class="upload-photo-preview" data-upload-target="photoPreview" style="display: none;"></div>

      <div class="upload-tips">
        <div class="upload-tip">
          <i class="fa-solid fa-sun"></i>
          <span>Good lighting, no glare</span>
        </div>
        <div class="upload-tip">
          <i class="fa-solid fa-bullseye"></i>
          <span>Sharp focus on branding</span>
        </div>
      </div>
    </div>

    <%# ── Section 3: Upload Video ── %>
    <div class="upload-section">
      <h2 class="upload-section-title">Upload Video</h2>
      <p class="upload-section-desc">Upload your high-quality video tutorial and the corresponding summary.</p>

      <label class="upload-dropzone" for="video_file" data-upload-target="videoDropzone">
        <div class="upload-dropzone-icon" data-upload-target="videoIcon">
          <i class="fa-regular fa-video"></i>
        </div>
        <p class="upload-dropzone-title" data-upload-target="videoTitle">Upload Video</p>
        <p class="upload-dropzone-sub" data-upload-target="videoSub">MP4, MOV up to 500MB</p>
        <%= file_field_tag :video_file, accept: "video/*", required: true,
              class: "upload-file-input", id: "video_file",
              data: { action: "change->upload#previewVideo" } %>
      </label>

      <div class="upload-input-wrapper upload-summary-wrapper">
        <%= f.text_area :summary,
              placeholder: "Add video summary ...",
              class: "upload-summary",
              rows: 4,
              data: { upload_target: "summary", action: "input->upload#updateSummaryCheck" } %>
        <i class="fa-regular fa-circle-check upload-input-check upload-summary-check" id="summaryCheck"></i>
      </div>
    </div>

    <%# ── Submit ── %>
    <div class="upload-submit-wrapper">
      <%= f.submit "Upload", class: "upload-submit-btn" %>
    </div>

  <% end %>
</div>
