<%# Upload video — device identification (video, script, photos, tags) %>
<div class="creator-submission-page">
  <div class="creator-submission-header">
    <%= link_to profile_path, class: "creator-submission-back" do %>
      <i class="fa-solid fa-arrow-left"></i>
    <% end %>
    <h1 class="creator-submission-title">Upload Video</h1>
  </div>

  <div class="creator-submission-progress mb-3">
    <span class="text-muted small">STEP 2 OF 3</span>
    <span class="ms-2 fw-semibold">Device Identification</span>
    <span class="text-muted small ms-auto">66% Complete</span>
  </div>
  <div class="progress mb-4" style="height: 6px;">
    <div class="progress-bar" role="progressbar" style="width: 66%; background: #4ECDC4;"></div>
  </div>

  <%= form_with url: videos_path, method: :post, local: true, html: { multipart: true, class: "creator-submission-form" } do |f| %>

    <div class="mb-4">
      <label class="form-label fw-bold">Confirm Device Model</label>
      <div class="d-flex align-items-center gap-2">
        <input type="text"
               name="target_model_name"
               class="form-control"
               placeholder="e.g. Sony WH-1000XM5"
               value="<%= params[:target_model_name] %>"
               required>
        <span class="text-success" title="Required"><i class="fa-solid fa-circle-check"></i></span>
      </div>
      <p class="form-text text-muted small mt-1">Ensure the model name exactly matches the label on your device or its original packaging.</p>
    </div>

    <div class="mb-4">
      <label class="form-label fw-bold">Upload Device Photo</label>
      <p class="text-muted small">Please take clear, well-lit photos of the physical device (at least one). This helps us verify the version.</p>
      <div class="creator-upload-zone">
        <label class="creator-upload-label">
          <i class="fa-solid fa-camera fa-2x text-primary mb-2"></i>
          <span>Tap to upload photos</span>
          <span class="small text-muted d-block mt-1">JPG, PNG up to 10MB</span>
          <input type="file" name="device_photos[]" accept="image/jpeg,image/png" multiple class="d-none">
        </label>
      </div>
      <div class="d-flex gap-2 mt-2 flex-wrap">
        <span class="badge bg-light text-dark border"><i class="fa-solid fa-sun me-1"></i> Good lighting, no glare</span>
        <span class="badge bg-light text-dark border"><i class="fa-solid fa-up-down-left-right me-1"></i> Sharp focus on branding</span>
      </div>
    </div>

    <div class="mb-4">
      <label class="form-label fw-bold">Upload Video Tutorial & Script</label>
      <p class="text-muted small">Upload your high-quality video tutorial and the corresponding script for review.</p>
      <div class="row g-2">
        <div class="col-12 col-md-6">
          <label class="creator-upload-zone creator-upload-zone-sm">
            <i class="fa-solid fa-video fa-2x text-primary mb-2"></i>
            <span>Upload Video</span>
            <span class="small text-muted d-block">MP4, MOV up to 500MB</span>
            <input type="file" name="video_file" accept="video/mp4,video/quicktime" class="d-none">
          </label>
        </div>
        <div class="col-12 col-md-6">
          <label class="creator-upload-zone creator-upload-zone-sm">
            <i class="fa-solid fa-file-lines fa-2x text-primary mb-2"></i>
            <span>Upload Script</span>
            <span class="small text-muted d-block">PDF, DOCX up to 20MB</span>
            <input type="file" name="script_file" accept=".pdf,.docx,application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document" class="d-none">
          </label>
        </div>
      </div>
    </div>

    <div class="mb-4">
      <label class="form-label fw-bold">Add Tags</label>
      <p class="text-muted small">Add descriptive keywords for the device or video content (e.g., noise cancelling, wireless, setup).</p>
      <input type="text"
             name="tags"
             class="form-control"
             placeholder="e.g. headphones, Sony, noise cancelling, wireless (comma-separated)">
    </div>

    <div class="mb-4">
      <label class="form-label fw-bold">Category</label>
      <select name="category_id" class="form-select">
        <% @categories.each do |cat| %>
          <option value="<%= cat.category_name %>"><%= cat.category_name %></option>
        <% end %>
      </select>
    </div>

    <button type="submit" class="btn btn-primary w-100 py-3 fw-bold creator-submit-btn">
      Submit for Review <i class="fa-solid fa-arrow-right ms-2"></i>
    </button>
    <p class="text-muted small text-center mt-2">Drafts are saved automatically as you progress.</p>
  <% end %>
</div>
