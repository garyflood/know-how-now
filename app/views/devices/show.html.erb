<%# Device show page — matches Know-How UI design %>
<% content_for :title, @device.name %>

<div class="device-page">

  <%# Header: back arrow + identified label + device name %>
  <div class="device-header">
    <%= link_to :back, class: "device-back-link" do %>
      <i class="fa-solid fa-arrow-left"></i>
    <% end %>
    <div class="device-header-info">
      <span class="device-identified-label">IDENTIFIED DEVICE</span>
      <h1 class="device-title"><%= @device.name %></h1>
    </div>
  </div>

  <%# Hero image with verified badge %>
  <div class="device-hero">
    <% if @device.images.count > 1 %>
      <div class="device-hero-slides">
        <% @device.images.each_with_index do |url, i| %>
          <%= image_tag url, class: "device-hero-img#{i.zero? ? ' device-hero-img--active' : ''}", alt: @device.name %>
        <% end %>
      </div>
    <% else %>
      <%= device_image_tag(@device, class: "device-hero-img", alt: @device.name) %>
    <% end %>
    <span class="device-verified-badge">
      <i class="fa-solid fa-circle-check"></i> VERIFIED MODEL
    </span>
    <h2 class="device-hero-name"><%= @device.name %></h2>
  </div>

  <%# Action buttons — both always shown; video button indicates availability %>
  <div class="device-actions">

    <%# Watch Video Guide — dimmed with notice if no video exists %>
    <%= link_to (@device.video.present? ? device_video_path(@device, @device.video) : nil), class: "btn device-btn-video #{'device-btn-video--unavailable' unless @device.video.present?}" do %>
      <div class="device-btn-icon">
        <i class="fa-solid fa-play"></i>
      </div>
      <div class="device-btn-label">
        <span>Watch Video Guide</span>
        <% if @device.video.present? %>
          <span class="device-btn-status device-btn-status--available">
            <span class="device-btn-dot"></span><span>Available</span>
          </span>
        <% else %>
          <span class="device-btn-status device-btn-status--unavailable">
            No video available
          </span>
        <% end %>
      </div>
    <% end %>

    <%# Read Manual — always available %>
    <%= link_to manual_device_path(@device), class: "btn device-btn-manual" do %>
      <div class="device-btn-icon">
        <i class="fa-solid fa-book-open"></i>
      </div>
      <div class="device-btn-label">
        <span>Read Manual</span>
        <span class="device-btn-status device-btn-status--available">
          <span class="device-btn-dot"></span><span>Available</span>
        </span>
      </div>
    <% end %>

  </div>

  <%# Related devices — horizontal scroll with images %>
  <% if @device.related_devices.present? %>
    <div class="device-related-section">
      <p class="device-related-label">
        <i class="fa-solid fa-rotate-left"></i>
        SPECIFY MODEL/SELECT A DIFFERENT MODEL
      </p>

      <div class="device-related-scroll" id="carouselOuter" data-controller="carousel">
        <div class="device-carousel-inner" id="carouselInner">

          <%# Current device card — highlighted as selected; click stays on same device page %>
          <%= link_to device_path(@device), class: "device-related-card device-related-card--active" do %>
            <%= device_image_tag(@device, class: "device-related-img", alt: @device.name) %>
            <span class="device-related-check"><i class="fa-solid fa-check"></i></span>
            <p class="device-related-name"><%= @device.name %></p>
          <% end %>

          <%# Other models — link to device page when it exists, otherwise POST to create/find %>
          <% @device.related_devices.each do |related_name| %>
            <% related = Device.find_by(name: related_name) %>
            <% active = related == @device %>
            <% if related %>
              <%= link_to device_path(related, **(params[:from].present? ? { from: params[:from] } : {})), class: "device-related-card #{'device-related-card--active' if active}" do %>
                <%= device_image_tag(related, class: "device-related-img", alt: related_name) %>
                <% if active %><span class="device-related-check"><i class="fa-solid fa-check"></i></span><% end %>
                <p class="device-related-name"><%= related_name %></p>
              <% end %>
            <% else %>
              <%= button_to devices_path, method: :post,
                            params: { device: { name: related_name }, from: params[:from] }.compact,
                            class: "device-related-card" do %>
                <%= category_image_tag(@device.category, class: "device-related-img", alt: related_name) %>
                <p class="device-related-name"><%= related_name %></p>
              <% end %>
            <% end %>
          <% end %>

        </div>
      </div>
    </div>

    <%# See More — opens the full related devices list page %>
    <div class="device-see-more-wrapper">
      <%= link_to "Click to See More", related_device_path(@device), class: "btn device-see-more-btn" %>
    </div>
  <% end %>

</div>

<%# CSS/JS ticker carousel — duplicate cards and drive smooth horizontal scroll %>
<script>
  // Remove layout's inline padding-bottom so no gap appears below the page content
  const mainEl = document.querySelector("main");
  if (mainEl) mainEl.style.paddingBottom = "0";

  const slides = document.querySelectorAll(".device-hero-slides .device-hero-img");
  if (slides.length > 1) {
    let current = 0;
    setInterval(function () {
      slides[current].classList.remove("device-hero-img--active");
      current = (current + 1) % slides.length;
      slides[current].classList.add("device-hero-img--active");
    }, 3500);
  }

  // Infinite auto-scrolling marquee for "Specify model/select a different model"
  function initCarousel() {
    const outer = document.getElementById("carouselOuter");
    const inner = document.getElementById("carouselInner");
    if (!outer || !inner || inner.children.length === 0) return;

    // Duplicate content for seamless infinite loop (as cards exit left, copy appears on right)
    inner.innerHTML += inner.innerHTML;
    void outer.offsetHeight; // force reflow so scrollWidth is correct

    let isPaused = false;
    let isDragging = false;
    let startX = 0;
    let startScroll = 0;
    let resumeTimeout = null;

    function step() {
      if (!outer || !inner) return;
      if (!isPaused && !isDragging) {
        outer.scrollLeft += 0.5;
        var halfWidth = inner.scrollWidth / 2;
        if (halfWidth > 0 && outer.scrollLeft >= halfWidth) {
          outer.scrollLeft -= halfWidth;
        }
      }
      requestAnimationFrame(step);
    }
    // Start after a short delay so layout is complete (helps after Turbo navigation)
    setTimeout(function () {
      if (outer && inner) requestAnimationFrame(step);
    }, 80);

    function pause() {
      isPaused = true;
      if (resumeTimeout) {
        clearTimeout(resumeTimeout);
        resumeTimeout = null;
      }
    }

    function resume() {
      if (resumeTimeout) clearTimeout(resumeTimeout);
      resumeTimeout = setTimeout(function () {
        resumeTimeout = null;
        isPaused = false;
      }, 300);
    }

    // Pause on hover (desktop)
    outer.addEventListener("mouseenter", pause);
    outer.addEventListener("mouseleave", function () {
      if (!isDragging) resume();
    });

    // Touch: pause, allow horizontal drag; only count as "drag" if moved past threshold (so taps still open links)
    var touchStartX = 0;
    outer.addEventListener("touchstart", function (e) {
      touchDidDrag = false;
      touchStartX = e.touches[0].pageX;
      isDragging = true;
      pause();
      startX = e.touches[0].pageX;
      startScroll = outer.scrollLeft;
    }, { passive: true });

    outer.addEventListener("touchmove", function (e) {
      if (!e.touches[0]) return;
      var dx = e.touches[0].pageX - startX;
      if (Math.abs(e.touches[0].pageX - touchStartX) > 10) touchDidDrag = true;
      var half = inner.scrollWidth / 2;
      outer.scrollLeft = Math.max(0, Math.min(half - 1, startScroll - dx));
      startX = e.touches[0].pageX;
      startScroll = outer.scrollLeft;
    }, { passive: true });

    outer.addEventListener("touchend", function () {
      isDragging = false;
      startScroll = outer.scrollLeft;
      resume();
    });

    // Mouse drag: only treat as drag if user moves past threshold so card links still work
    var dragStartX = 0;
    var didDrag = false;
    var touchDidDrag = false;

    outer.addEventListener("mousedown", function (e) {
      dragStartX = e.pageX;
      didDrag = false;

      function onMove(ev) {
        var dx = Math.abs(ev.pageX - dragStartX);
        if (dx > 5 && !didDrag) {
          didDrag = true;
          isDragging = true;
          pause();
          outer.classList.add("dragging");
          startX = ev.pageX;
          startScroll = outer.scrollLeft;
        }
        if (didDrag) {
          var d = ev.pageX - startX;
          startX = ev.pageX;
          var half = inner.scrollWidth / 2;
          outer.scrollLeft = Math.max(0, Math.min(half - 1, outer.scrollLeft - d));
          startScroll = outer.scrollLeft;
        }
      }

      function onUp() {
        if (didDrag) {
          isDragging = false;
          outer.classList.remove("dragging");
          resume();
        }
        document.removeEventListener("mousemove", onMove);
        document.removeEventListener("mouseup", onUp);
      }

      document.addEventListener("mousemove", onMove);
      document.addEventListener("mouseup", onUp);
    });

    // If user dragged (mouse or touch), prevent card link/form from firing
    outer.addEventListener("click", function (e) {
      if (didDrag || touchDidDrag) {
        e.preventDefault();
        e.stopPropagation();
      }
    }, true);
  }

  // Run when this page's script executes (after full load or after Turbo replaces body with this page)
  initCarousel();
</script>
