<div data-controller="camera">

  <%# Shown when camera permission is denied or not yet granted %>
  <div data-camera-target="permissionPrompt" class="text-center mb-4 p-4 rounded border">
    <p class="text-muted mb-3">Enable your camera to take a photo of your device</p>
    <button type="button"
            class="btn camera-permission-btn"
            data-action="click->camera#requestCamera">
      Enable Camera
    </button>
    <p data-camera-target="deniedMessage" class="text-danger mt-3 mb-0 d-none small">
      Camera access was denied. Please enable it in your browser or device settings and reload the page.
    </p>
  </div>

  <%# Camera section — hidden until permission is granted %>
  <div data-camera-target="cameraSection" class="d-none">
    <div class="camera-container">

      <%# Live video stream %>
      <video data-camera-target="video"
             autoplay
             playsinline
             muted
             class="camera-video"></video>

      <%# Frozen frame canvas — shown over video after capture %>
      <canvas data-camera-target="canvas" class="camera-frozen-frame d-none"></canvas>

      <%# Viewfinder corner brackets %>
      <div class="camera-viewfinder">
        <div class="vf-corner vf-tl"></div>
        <div class="vf-corner vf-tr"></div>
        <div class="vf-corner vf-bl"></div>
        <div class="vf-corner vf-br"></div>
        <div class="vf-scan-line" data-camera-target="scanLine"></div>
      </div>

      <%# Hint label %>
      <div class="camera-hint<%= ' camera-hint--error' if @not_a_device %>" data-camera-target="hint"><% if @not_a_device %>not a device - capture a device to identify<% else %>capture a device to identify<% end %></div>

      <%# Circle capture button — no text %>
      <button type="button"
              class="capture-btn"
              data-camera-target="captureBtn"
              data-action="click->camera#capture"
              aria-label="Take picture"></button>

    </div>
  </div>

  <%# Always-visible form: text input + upload button %>
  <%= simple_form_for @device || Device.new,
                      url: devices_path,
                      html: { multipart: true, "data-quick-add-target": "form" } do |f| %>

    <%# Hidden field receives the base64 data URI from the camera capture %>
    <input type="hidden" name="device_camera_image" data-camera-target="capturedImageInput">

    <div class="camera-bottom-bar" data-camera-target="bottomBar">
      <%= f.input :name,
                  placeholder: "Search Manually ...",
                  label: false,
                  wrapper: false,
                  input_html: { class: "form-control camera-search-input", "data-quick-add-target": "nameInput", "data-action": "keydown.enter->camera#submitForm" } %>
      <label for="device_image" class="upload-icon-btn" title="Upload image">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" viewBox="0 0 16 16">
          <path d="M6.002 5.5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0z"/>
          <path d="M2.002 1a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V3a2 2 0 0 0-2-2h-12zm12 1a1 1 0 0 1 1 1v6.5l-3.777-1.947a.5.5 0 0 0-.577.093l-3.71 3.71-2.66-1.772a.5.5 0 0 0-.63.062L1.002 12V3a1 1 0 0 1 1-1h12z"/>
        </svg>
      </label>
      <input type="file" id="device_image" name="device_image" accept="image/*" class="d-none" data-action="change->camera#uploadAndSubmit">
    </div>

  <% end %>

</div>
