<%# Explore: browse categories (with images), then devices in a category %>
<div class="w-100">
  <h1 class="mb-4">Explore</h1>
  <p class="text-muted mb-4">Choose a category to browse devices.</p>

  <div class="row g-3">
    <% @categories.each do |category| %>
      <div class="col-6 col-md-4 col-lg-3">
        <%= link_to explore_category_path(category), class: "text-decoration-none text-dark" do %>
          <div class="card h-100 explore-category-card border rounded shadow-sm">
            <div class="explore-category-card-img-wrapper">
              <%= category_image_tag(category, class: "card-img-top", alt: category.category_name) %>
            </div>
            <div class="card-body py-2 text-center">
              <span class="card-title small fw-semibold"><%= category.category_name %></span>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
